<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Blue -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="PrimaryActiveColor">#1E40AF</Color>
    <Color x:Key="PrimaryLightColor">#EFF6FF</Color>
    <Color x:Key="PrimarySoftColor">#DBEAFE</Color>

    <!-- Background -->
    <Color x:Key="AppBackgroundColor">#F8FAFC</Color>
    <Color x:Key="MainSurfaceColor">#FFFFFF</Color>
    <Color x:Key="SecondarySurfaceColor">#F1F5F9</Color>
    <Color x:Key="HoverSurfaceColor">#F8FAFF</Color>
    <Color x:Key="SelectedSurfaceColor">#EFF6FF</Color>

    <!-- Border & Divider -->
    <Color x:Key="BorderDefaultColor">#E2E8F0</Color>
    <Color x:Key="BorderStrongColor">#CBD5E1</Color>
    <Color x:Key="BorderSelectedColor">#93C5FD</Color>
    <Color x:Key="DividerColor">#E5E7EB</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#0F172A</Color>
    <Color x:Key="TextSecondaryColor">#475569</Color>
    <Color x:Key="TextTertiaryColor">#94A3B8</Color>
    <Color x:Key="TextDisabledColor">#CBD5E1</Color>
    <Color x:Key="TextLinkColor">#2563EB</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="InfoColor">#2563EB</Color>

    <!-- Keycap -->
    <Color x:Key="KeycapBackgroundColor">#EFF6FF</Color>
    <Color x:Key="KeycapBorderColor">#BFDBFE</Color>
    <Color x:Key="KeycapTextColor">#1D4ED8</Color>
    <Color x:Key="KeycapPlusColor">#60A5FA</Color>

    <!-- Solid Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}" />
    <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource PrimaryActiveColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource PrimarySoftColor}" />
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="MainSurfaceBrush" Color="{StaticResource MainSurfaceColor}" />
    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="{StaticResource SecondarySurfaceColor}" />
    <SolidColorBrush x:Key="HoverSurfaceBrush" Color="{StaticResource HoverSurfaceColor}" />
    <SolidColorBrush x:Key="SelectedSurfaceBrush" Color="{StaticResource SelectedSurfaceColor}" />
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="BorderSelectedBrush" Color="{StaticResource BorderSelectedColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="TextLinkBrush" Color="{StaticResource TextLinkColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="KeycapBackgroundBrush" Color="{StaticResource KeycapBackgroundColor}" />
    <SolidColorBrush x:Key="KeycapBorderBrush" Color="{StaticResource KeycapBorderColor}" />
    <SolidColorBrush x:Key="KeycapTextBrush" Color="{StaticResource KeycapTextColor}" />
    <SolidColorBrush x:Key="KeycapPlusBrush" Color="{StaticResource KeycapPlusColor}" />
</ResourceDictionary>
