<Window x:Class="ContextKeys.Views.DelayInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加延迟" Width="360" Height="180"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border Padding="24" Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource PageTitleStyle}">添加延迟</TextBlock>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16,0,0">
                <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                    延迟时间（毫秒）：
                </TextBlock>
                <TextBox x:Name="DelayMsBox" Style="{StaticResource FormTextBoxStyle}"
                         Text="100" PreviewTextInput="DelayMsBox_PreviewTextInput" />
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Width="80" Margin="0,0,8,0"
                        Click="Cancel_Click">取消</Button>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Click="Confirm_Click">确定</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
