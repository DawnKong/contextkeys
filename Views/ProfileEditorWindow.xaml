<Window x:Class="ContextKeys.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑配置" Width="640" Height="560"
        MinWidth="560" MinHeight="480"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Border Padding="24" Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleStyle}">配置设置</TextBlock>

                    <!-- Profile Name -->
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Style="{StaticResource SubSectionTitleStyle}">配置名称</TextBlock>
                        <Grid>
                            <TextBox x:Name="ProfileNameBox" Style="{StaticResource FormTextBoxStyle}"
                                     Text="" TextChanged="ProfileNameBox_TextChanged"
                                     GotFocus="ProfileNameBox_GotFocus"
                                     LostFocus="ProfileNameBox_LostFocus" />
                            <TextBlock x:Name="ProfileNameHint" FontSize="14"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="14,0,0,0"
                                       IsHitTestVisible="False"
                                       Text="自定义 / 绑定窗口后自动生成" />
                        </Grid>
                    </StackPanel>

                    <!-- Window Binding -->
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Style="{StaticResource SubSectionTitleStyle}">绑定窗口</TextBlock>

                        <Border Style="{StaticResource InfoCardStyle}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,8" VerticalAlignment="Center">应用</TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="WinProcessName" Text="-" />
                                </TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,8" VerticalAlignment="Center">标题关键词</TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TitleContainsBox" Style="{StaticResource FormTextBoxStyle}"
                                         Height="32" Margin="0,0,0,8" />
                            </Grid>
                        </Border>

                        <Button x:Name="BindWindowBtn" Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Padding="12,0" FontSize="13"
                                Width="140" HorizontalAlignment="Left"
                                Click="BindWindow_Click">
                            绑定窗口
                        </Button>
                    </StackPanel>

                    <!-- Hotkey Rules -->
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Style="{StaticResource SubSectionTitleStyle}">快捷键规则</TextBlock>

                        <ItemsControl x:Name="RulesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Style="{StaticResource KeycapStyle}">
                                                    <TextBlock Style="{StaticResource KeycapTextStyle}">
                                                        <Run Text="{Binding Hotkey.Display}" />
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Grid.Column="1" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <Run Text="{Binding Name}" />
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Run Text="{Binding Actions.Count, Mode=OneWay, StringFormat={}{0} 个动作}" />
                                                </TextBlock>
                                                <CheckBox Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                          ToolTip="启用/停用此规则" />
                                            </Grid>

                                            <!-- Rule action buttons (right-aligned icons) -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Margin="0,4,0,0">
                                                <Button Content="⚙" Style="{StaticResource SecondaryButtonStyle}"
                                                        Height="26" Width="26" Padding="0" FontSize="14"
                                                        Margin="0,0,4,0" ToolTip="编辑"
                                                        Click="EditRule_Click"
                                                        Tag="{Binding}" />
                                                <Button Content="🗑" Style="{StaticResource DangerButtonStyle}"
                                                        Height="26" Width="26" Padding="0" FontSize="14"
                                                        ToolTip="删除"
                                                        Click="DeleteRule_Click"
                                                        Tag="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button x:Name="AddRuleBtn" Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" Padding="12,0" FontSize="13"
                                Width="140" HorizontalAlignment="Left"
                                Click="AddRule_Click">
                            + 添加快捷键
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Style="{StaticResource SecondaryButtonStyle}"
                        Width="80" Margin="0,0,8,0"
                        Click="Cancel_Click">取消</Button>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Click="Save_Click">保存</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
