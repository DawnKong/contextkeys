<Application x:Class="ContextKeys.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utils="clr-namespace:ContextKeys.Utils"
             xmlns:local="clr-namespace:ContextKeys"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Colors.xaml" />
                <ResourceDictionary Source="Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <utils:BooleanToVisibilityConverter x:Key="BoolToVis" />
            <utils:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
