<Window x:Class="ContextKeys.Services.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Width="360"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Focusable="False"
        WindowStartupLocation="Manual">
    <Border Background="Transparent" Padding="0">
        <Border Style="{StaticResource CardStyle}"
                BorderBrush="{StaticResource KeycapBorderBrush}"
                Background="{StaticResource MainSurfaceBrush}"
                CornerRadius="14"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left accent bar -->
                    <Rectangle Grid.Column="0" Fill="{StaticResource PrimaryBrush}"
                               Width="4" RadiusX="2" RadiusY="2"
                               HorizontalAlignment="Left" VerticalAlignment="Stretch" />

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock x:Name="ToastTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            已启用：ChatGPT 快捷语
                        </TextBlock>
                        <ItemsControl x:Name="ToastRules">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource KeycapStyle}"
                                                Height="20" Padding="6,0" Margin="0,0,6,0">
                                            <TextBlock Style="{StaticResource KeycapTextStyle}" FontSize="11">
                                                <Run Text="{Binding Hotkey.Display}" />
                                            </TextBlock>
                                        </Border>
                                        <TextBlock Grid.Column="1" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Name}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
